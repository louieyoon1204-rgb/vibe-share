# Vibe Share environment template
# Copy this file to .env when you want local overrides.

############################################################
# Local demo mode: minimum setup, no Docker required
############################################################
APP_MODE=development
SERVER_PORT=4000
CORS_ORIGIN=*

DATABASE_DRIVER=json
CACHE_DRIVER=memory
SOCKET_IO_ADAPTER=memory
STORAGE_DRIVER=local

UPLOAD_DIR=.tmp/uploads
METADATA_FILE=.tmp/metadata.json

SESSION_TTL_MS=1800000
TRANSFER_TTL_MS=3600000
CLEANUP_INTERVAL_MS=60000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600

MAX_FILE_SIZE_GB=100
UPLOAD_CHUNK_SIZE_MB=16
UPLOAD_CHUNK_MAX_MB=64
SIGNED_URL_TTL_SECONDS=900
LEGACY_RELAY_MAX_FILE_SIZE_MB=100

# Empty means allow all MIME types in local demo mode.
ALLOWED_MIME_TYPES=

VITE_SERVER_URL=http://localhost:4000

# Product surface defaults. These are documented targets only until DNS/hosting is configured.
PUBLIC_SITE_URL=https://vibeshare.app
PUBLIC_WEB_APP_URL=https://app.vibeshare.app
PUBLIC_API_URL=https://api.vibeshare.app

# Usually leave blank. The PC QR carries the LAN server URL.
# For manual-only testing from a phone, set http://YOUR_PC_LAN_IP:4000
EXPO_PUBLIC_SERVER_URL=

############################################################
# Staging deployment target
############################################################
# Use .env.staging.example as the deploy-ready template for:
#   https://staging.vibeshare.app
#   https://app-staging.vibeshare.app
#   https://api-staging.vibeshare.app

############################################################
# Production-like local mode with docker-compose.local-infra.yml
############################################################
# APP_MODE=development
# DATABASE_DRIVER=postgres
# CACHE_DRIVER=redis
# SOCKET_IO_ADAPTER=redis
# STORAGE_DRIVER=s3
#
# DATABASE_URL=postgres://vibeshare:vibeshare@127.0.0.1:5432/vibeshare
# REDIS_URL=redis://127.0.0.1:6379
#
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=vibe-share-transfers
# S3_ACCESS_KEY_ID=vibeshare
# S3_SECRET_ACCESS_KEY=vibeshare-secret
# S3_FORCE_PATH_STYLE=true
#
# DEVICE_TRUST_SECRET=replace-with-local-long-random-secret
# ADMIN_TOKEN=replace-with-local-admin-token

############################################################
# Production deployment mode
############################################################
# APP_MODE=production
# DATABASE_DRIVER=postgres
# CACHE_DRIVER=redis
# SOCKET_IO_ADAPTER=redis
# STORAGE_DRIVER=s3
#
# DATABASE_URL=postgres://user:password@db.example.com:5432/vibeshare
# REDIS_URL=redis://redis.example.com:6379
#
# S3_ENDPOINT=https://s3.example.com
# S3_REGION=us-east-1
# S3_BUCKET=vibe-share-transfers
# S3_ACCESS_KEY_ID=change-me
# S3_SECRET_ACCESS_KEY=change-me
# S3_FORCE_PATH_STYLE=false
#
# DEVICE_TRUST_SECRET=change-me-to-a-long-random-secret
# ADMIN_TOKEN=change-me-to-a-long-random-admin-token
# AUTH_JWT_ISSUER=https://auth.example.com
# AUTH_JWT_AUDIENCE=vibe-share
# AUTH_JWT_SECRET=change-me-if-using-local-jwt-validation
# AUTH_DEV_LOGIN_ENABLED=false
# AUTH_TOKEN_TTL_SECONDS=604800
# REQUIRE_DEVICE_TRUST=true

############################################################
# Security and compliance hook points
############################################################
# MALWARE_SCAN_WEBHOOK_URL=https://scanner.example.com/scan
# AUDIT_LOG_SINK=
# LOG_LEVEL=info
