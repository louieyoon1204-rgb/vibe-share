# Vibe Share staging environment template
# Put these values in the staging host secret manager. Do not commit real secrets.

APP_MODE=production
SERVER_PORT=4000
CORS_ORIGIN=https://app-staging.vibeshare.app

DATABASE_DRIVER=postgres
CACHE_DRIVER=redis
SOCKET_IO_ADAPTER=redis
STORAGE_DRIVER=s3

DATABASE_URL=postgres://user:password@staging-postgres.example.com:5432/vibeshare
REDIS_URL=redis://staging-redis.example.com:6379

# Cloudflare R2 S3 API account endpoint. Do not use a bucket URL, r2.dev URL, or custom domain.
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=vibe-share-staging-transfers
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=false

DEVICE_TRUST_SECRET=change-me-to-a-long-random-staging-secret
ADMIN_TOKEN=change-me-to-a-long-random-staging-admin-token
AUTH_JWT_SECRET=change-me-to-a-long-random-staging-auth-secret
AUTH_DEV_LOGIN_ENABLED=false
AUTH_TOKEN_TTL_SECONDS=604800
REQUIRE_DEVICE_TRUST=true

MAX_FILE_SIZE_GB=100
UPLOAD_CHUNK_SIZE_MB=16
UPLOAD_CHUNK_MAX_MB=64
SIGNED_URL_TTL_SECONDS=900
LEGACY_RELAY_MAX_FILE_SIZE_MB=100

VITE_SERVER_URL=https://api-staging.vibeshare.app
PUBLIC_SITE_URL=https://staging.vibeshare.app
PUBLIC_WEB_APP_URL=https://app-staging.vibeshare.app
PUBLIC_API_URL=https://api-staging.vibeshare.app
EXPO_PUBLIC_SERVER_URL=https://api-staging.vibeshare.app

MALWARE_SCAN_WEBHOOK_URL=https://scanner-staging.example.com/scan
AUDIT_LOG_SINK=
LOG_LEVEL=info
