APP_MODE=development
SERVER_PORT=4000
CORS_ORIGIN=*

DATABASE_DRIVER=postgres
CACHE_DRIVER=redis
SOCKET_IO_ADAPTER=redis
STORAGE_DRIVER=s3

DATABASE_URL=postgres://vibeshare:vibeshare@127.0.0.1:5432/vibeshare
REDIS_URL=redis://127.0.0.1:6379

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=vibe-share-transfers
S3_ACCESS_KEY_ID=vibeshare
S3_SECRET_ACCESS_KEY=vibeshare-secret
S3_FORCE_PATH_STYLE=true

DEVICE_TRUST_SECRET=local-dev-device-trust-secret-change-before-production
ADMIN_TOKEN=local-dev-admin-token
AUTH_DEV_LOGIN_ENABLED=true
AUTH_TOKEN_TTL_SECONDS=604800
REQUIRE_DEVICE_TRUST=false

MAX_FILE_SIZE_GB=100
UPLOAD_CHUNK_SIZE_MB=16
UPLOAD_CHUNK_MAX_MB=64
SIGNED_URL_TTL_SECONDS=900
LEGACY_RELAY_MAX_FILE_SIZE_MB=100

VITE_SERVER_URL=http://localhost:4000
PUBLIC_SITE_URL=https://vibeshare.app
PUBLIC_WEB_APP_URL=https://app.vibeshare.app
PUBLIC_API_URL=https://api.vibeshare.app
EXPO_PUBLIC_SERVER_URL=
