/index.html
  Cache-Control: no-store, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0

/_redirects
  Cache-Control: no-store, max-age=0, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/*
  X-Content-Type-Options: nosniff
